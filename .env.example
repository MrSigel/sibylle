# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Tag / Google Ads (für Ads + Conversion-Tracking)
# GA4 Mess-ID (GA4 -> Verwaltung -> Datenströme), Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Ads Conversion-ID (Ads -> Tools -> Conversions -> Tag-Einrichtung), Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Conversion-Labels (Ads -> Conversions -> jeweilige Aktion -> Teil nach dem "/" der send_to-ID)
NEXT_PUBLIC_ADS_LABEL_WHATSAPP=
NEXT_PUBLIC_ADS_LABEL_BOOKING=

# CRM Admin Credentials
CRM_ADMIN_EMAIL=
CRM_ADMIN_PASSWORD=
CRM_SESSION_SECRET=

# CRM Mailbox - STRATO SMTP/IMAP
MAIL_FROM_NAME=Sibylle Bergold
MAIL_FROM_ADDRESS=kontakt@sibylle-bergold.com

SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=kontakt@sibylle-bergold.com
SMTP_PASSWORD=

IMAP_HOST=imap.strato.de
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=kontakt@sibylle-bergold.com
IMAP_PASSWORD=
IMAP_INBOX_MAILBOX=INBOX
# STRATO nennt den Gesendet-Ordner "Sent Items" (nicht "Sent"). Wird zur
# Sicherheit auch automatisch per IMAP special-use erkannt.
IMAP_SENT_MAILBOX=Sent Items
